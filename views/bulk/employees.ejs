<% title = 'Bulk Import Employees' %>
<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h4 class="fw-bold mb-0"><i class="bi bi-upload me-2"></i> Bulk Import Employees</h4>
        <small class="text-muted">Import multiple employees/teachers from a CSV file</small>
    </div>
    <a href="/employees" class="btn btn-outline-secondary"><i class="bi bi-arrow-left"></i> Back</a>
</div>

<% if (success && results && results.length > 0) { %>
<div class="alert alert-success"><i class="bi bi-check-circle me-1"></i> <%= success %></div>
<div class="card mb-4">
    <div class="card-header bg-success text-white"><i class="bi bi-person-badge me-1"></i> Generated Credentials</div>
    <div class="table-responsive">
        <table class="table table-sm mb-0">
            <thead class="table-light">
                <tr><th>#</th><th>Emp ID</th><th>Name</th><th>Username</th><th>Password</th><th>Initials</th><th>Designation</th><th>Class Teacher</th><th>Subject Teacher</th></tr>
            </thead>
            <tbody>
                <% results.forEach((r, i) => { %>
                <tr>
                    <td><%= i + 1 %></td>
                    <td><code><%= r.emp_id %></code></td>
                    <td><%= r.name %></td>
                    <td><code><%= r.username %></code></td>
                    <td><code><%= r.password %></code></td>
                    <td><code><%= r.initials %></code></td>
                    <td><%= r.designation %></td>
                    <td><%= r.class || '-' %></td>
                    <td><%= r.subject || '-' %></td>
                </tr>
                <% }); %>
            </tbody>
        </table>
    </div>
</div>
<% } else if (success) { %>
<div class="alert alert-success"><i class="bi bi-check-circle me-1"></i> <%= success %></div>
<% } %>

<% if (preview && preview.tempFile) { %>
<div class="card mb-4 border-primary">
    <div class="card-header bg-primary text-white d-flex justify-content-between align-items-center">
        <span><i class="bi bi-eye me-1"></i> Preview — <%= preview.rows.length %> row(s)</span>
        <span class="badge bg-light text-primary"><%= preview.rows.filter(r => !r.errors.length).length %> valid</span>
    </div>
    <div class="table-responsive" style="max-height:400px">
        <table class="table table-sm table-bordered mb-0">
            <thead class="table-light sticky-top">
                <tr>
                    <th>#</th>
                    <% preview.headers.forEach(h => { %>
                    <th><%= h %></th>
                    <% }); %>
                    <th>Status</th>
                </tr>
            </thead>
            <tbody>
                <% preview.rows.forEach((r, i) => { %>
                <tr class="<%= r.errors.length ? 'table-danger' : 'table-success' %>">
                    <td><%= i + 1 %></td>
                    <% preview.headers.forEach(h => { %>
                    <td><%= r.data[h] || '-' %></td>
                    <% }); %>
                    <td>
                        <% if (r.errors.length) { %>
                        <span class="text-danger" title="<%= r.errors.join('; ') %>"><i class="bi bi-x-circle"></i> errors</span>
                        <% } else { %>
                        <span class="text-success"><i class="bi bi-check-circle"></i> ready</span>
                        <% } %>
                    </td>
                </tr>
                <% }); %>
            </tbody>
        </table>
    </div>
    <div class="card-footer bg-light">
        <form method="POST" action="/bulk/employees">
            <input type="hidden" name="_csrf" value="<%= csrfToken %>">
            <input type="hidden" name="confirm" value="1">
            <input type="hidden" name="_tempFile" value="<%= preview.tempFile %>">
            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-primary"><i class="bi bi-check-lg me-1"></i> Confirm Import</button>
                <a href="/bulk/employees" class="btn btn-outline-secondary"><i class="bi bi-x-lg me-1"></i> Cancel</a>
            </div>
        </form>
    </div>
</div>
<% } else if (preview) { %>
<div class="card mb-4 border-danger">
    <div class="card-header bg-danger text-white">
        <i class="bi bi-exclamation-triangle me-1"></i> Validation Errors — <%= preview.rows.length %> row(s)
    </div>
    <div class="table-responsive" style="max-height:400px">
        <table class="table table-sm table-bordered mb-0">
            <thead class="table-light sticky-top">
                <tr>
                    <th>#</th>
                    <% preview.headers.forEach(h => { %>
                    <th><%= h %></th>
                    <% }); %>
                    <th>Errors</th>
                </tr>
            </thead>
            <tbody>
                <% preview.rows.forEach((r, i) => { %>
                <tr class="<%= r.errors.length ? 'table-danger' : 'table-success' %>">
                    <td><%= i + 1 %></td>
                    <% preview.headers.forEach(h => { %>
                    <td><%= r.data[h] || '-' %></td>
                    <% }); %>
                    <td>
                        <% if (r.errors.length) { %>
                        <span class="text-danger"><%= r.errors.join('; ') %></span>
                        <% } else { %>
                        <span class="text-success">ok</span>
                        <% } %>
                    </td>
                </tr>
                <% }); %>
            </tbody>
        </table>
    </div>
    <div class="card-footer">
        <a href="/bulk/employees" class="btn btn-outline-secondary"><i class="bi bi-arrow-left me-1"></i> Fix &amp; Re-upload</a>
    </div>
</div>
<% } %>

<div class="card">
    <div class="card-body p-4">
        <h5 class="fw-semibold mb-3">CSV Format</h5>
        <div class="alert alert-info">
            <strong>Required column:</strong> <code>Name</code><br>
            <strong>Optional columns:</strong> <code>Sl no</code>, <code>Designation</code>, <code>Initial</code>, <code>Contact</code>, <code>Email</code>, <code>Class</code>, <code>Subject</code><br>
            <strong>Auto-generated:</strong> Employee ID, Username, Password (if no user account exists)
        </div>

        <div class="d-flex gap-2 mb-3">
            <a href="/bulk/template/employees" class="btn btn-sm btn-outline-success"><i class="bi bi-download me-1"></i> Download CSV Template</a>
        </div>
        <div class="bg-light rounded p-3 mb-4">
            <small class="text-muted d-block mb-2">Example CSV:</small>
            <code style="font-size:12px">Sl no,Designation,Name,Initial,Contact,Email,Class,Subject<br>1,Principal,Rajesh Sharma,PRP,9876543210,principal@school.edu,,<br>2,Teacher,Sunita Verma,SNV,9876543211,sunita@school.edu,I-A,Physics</code>
        </div>

        <% if (error) { %>
        <div class="alert alert-danger"><i class="bi bi-exclamation-triangle me-1"></i> <%= error %></div>
        <% } %>

        <form method="POST" action="/bulk/employees" enctype="multipart/form-data">
            <input type="hidden" name="_csrf" value="<%= csrfToken %>">
            <div class="mb-3">
                <label class="form-label">Select CSV File <span class="text-danger">*</span></label>
                <input type="file" name="file" class="form-control" accept=".csv" required>
            </div>
            <button type="submit" class="btn btn-primary"><i class="bi bi-upload me-1"></i> Preview &amp; Import</button>
        </form>
    </div>
</div>