<% title = 'My Profile' %>
<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h4 class="fw-bold mb-0"><i class="bi bi-person-circle me-2"></i> My Profile</h4>
        <small class="text-muted">View and edit your profile information</small>
    </div>
    <a href="/" class="btn btn-outline-secondary"><i class="bi bi-arrow-left"></i> Back</a>
</div>

<div class="row g-4">
    <div class="col-md-5">
        <div class="card">
            <div class="card-body text-center py-4">
                <div class="fs-1 text-primary mb-2"><i class="bi bi-person-circle"></i></div>
                <h5 class="fw-bold"><%= user.initials || user.username %></h5>
                <span class="badge bg-primary"><%= user.role %></span>
                <hr>
                <div class="text-start small">
                    <div class="mb-2"><strong>Username:</strong> <code><%= user.username %></code></div>
                    <div class="mb-2"><strong>Initials:</strong> <code><%= user.initials || '-' %></code></div>
                    <div class="mb-0"><strong>Role:</strong> <span class="badge bg-<%= user.role === 'admin' ? 'danger' : 'info' %>"><%= user.role %></span></div>
                </div>
            </div>
        </div>
    </div>

    <div class="col-md-7">
        <div class="card">
            <div class="card-header"><i class="bi bi-pencil me-1"></i> Edit Details</div>
            <div class="card-body">
                <% if (user.name) { %>
                <form method="POST" action="/profile">
                    <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                    <div class="mb-3">
                        <label class="form-label">Employee ID</label>
                        <input type="text" class="form-control" value="<%= user.username %>" readonly>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Full Name <span class="text-danger">*</span></label>
                        <input type="text" name="name" class="form-control" value="<%= user.name %>" required>
                        <div class="form-text">Fix spelling mistakes here if needed.</div>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Department</label>
                        <input type="text" class="form-control" value="<%= user.department || '-' %>" readonly>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Designation</label>
                        <input type="text" class="form-control" value="<%= user.designation || '-' %>" readonly>
                    </div>
                    <% if (user.class_teacher) { %>
                    <div class="mb-3">
                        <label class="form-label">Class Teacher</label>
                        <input type="text" class="form-control" value="<%= user.class_teacher %>" readonly>
                    </div>
                    <% } %>
                    <% if (user.subject_teacher) { %>
                    <div class="mb-3">
                        <label class="form-label">Subject Teacher</label>
                        <input type="text" class="form-control" value="<%= user.subject_teacher %>" readonly>
                    </div>
                    <% } %>
                    <div class="mb-3">
                        <label class="form-label">Email</label>
                        <input type="email" name="email" class="form-control" value="<%= user.email || '' %>">
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Phone</label>
                        <input type="text" name="phone" class="form-control" value="<%= user.phone || '' %>">
                    </div>
                    <button type="submit" class="btn btn-primary"><i class="bi bi-save me-1"></i> Save Changes</button>
                </form>
                <% } else { %>
                <div class="alert alert-warning mb-0">No employee record found for your account. Please contact the IT administrator.</div>
                <% } %>
            </div>
        </div>
    </div>
</div>
