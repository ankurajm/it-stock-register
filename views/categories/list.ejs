<% title = 'Categories' %>
<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h4 class="fw-bold mb-0"><i class="bi bi-tags me-2"></i> Categories</h4>
        <small class="text-muted">Manage item categories</small>
    </div>
    <a href="/categories/add" class="btn btn-primary"><i class="bi bi-plus-lg"></i> Add Category</a>
</div>

<div class="card">
    <div class="table-responsive">
        <table class="table table-hover mb-0">
            <thead class="table-light">
                <tr><th>Name</th><th>Prefix</th><th>Description</th><th>Items</th><th class="text-end">Actions</th></tr>
            </thead>
            <tbody>
                <% if (categories.length === 0) { %>
                <tr><td colspan="5" class="text-center text-muted py-5"><i class="bi bi-tags fs-3 d-block mb-2"></i> No categories</td></tr>
                <% } %>
                <% categories.forEach(c => { %>
                <tr>
                    <td class="fw-medium"><%= c.name %></td>
                    <td><code><%= c.prefix %></code></td>
                    <td><%= c.description || '-' %></td>
                    <td><span class="badge bg-secondary"><%= c.item_count || 0 %></span></td>
                    <td class="text-end">
                        <div class="btn-group btn-group-sm">
                            <a href="/categories/edit/<%= c.id %>" class="btn btn-outline-warning"><i class="bi bi-pencil"></i></a>
                            <form method="POST" action="/categories/delete/<%= c.id %>" style="display:inline" onsubmit="return confirm('Delete this category?')">
                                <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                                <button type="submit" class="btn btn-outline-danger"><i class="bi bi-trash"></i></button>
                            </form>
                        </div>
                    </td>
                </tr>
                <% }); %>
            </tbody>
        </table>
    </div>
</div>
