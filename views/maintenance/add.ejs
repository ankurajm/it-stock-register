<% title = record ? 'Edit Maintenance #' + record.id : 'Log Maintenance' %>
<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h4 class="fw-bold mb-0"><i class="bi bi-<%= record ? 'pencil' : 'plus' %>-circle me-2"></i> <%= record ? 'Edit' : 'Log' %> Maintenance</h4>
        <small class="text-muted"><%= record ? 'Update maintenance record' : 'Report a new issue for an IT asset' %></small>
    </div>
    <a href="/maintenance" class="btn btn-outline-secondary"><i class="bi bi-arrow-left"></i> Back</a>
</div>

<% if (error) { %>
<div class="alert alert-danger alert-dismissible fade show border-start border-danger border-4"><i class="bi bi-exclamation-triangle me-2"></i> <%= error %><button type="button" class="btn-close" data-bs-dismiss="alert"></button></div>
<% } %>

<div class="card">
    <div class="card-body p-4">
        <form method="POST" action="<%= record ? '/maintenance/edit/' + record.id : '/maintenance/add' %>">
            <input type="hidden" name="_csrf" value="<%= csrfToken %>">
            <div class="row g-3">
                <div class="col-md-6">
                    <label class="form-label">IT Asset <span class="text-danger">*</span></label>
                    <select name="item_id" class="form-select" <%= record ? 'disabled' : 'required' %>>
                        <option value="">-- Select Item --</option>
                        <% items.forEach(item => { %>
                        <option value="<%= item.id %>" <%= record && record.item_id === item.id ? 'selected' : '' %>><%= item.asset_tag %> — <%= item.category %><%= item.brand ? ' (' + item.brand + ')' : '' %></option>
                        <% }); %>
                    </select>
                    <% if (record) { %><input type="hidden" name="item_id" value="<%= record.item_id %>"><% } %>
                </div>
                <div class="col-md-3">
                    <label class="form-label">Issue Date <span class="text-danger">*</span></label>
                    <input type="date" name="issue_date" class="form-control" value="<%= record ? record.issue_date : new Date().toISOString().split('T')[0] %>" required>
                </div>
                <div class="col-md-3">
                    <label class="form-label">Status</label>
                    <select name="status" class="form-select">
                        <option value="pending" <%= !record || record.status === 'pending' ? 'selected' : '' %>>Pending</option>
                        <option value="in-progress" <%= record && record.status === 'in-progress' ? 'selected' : '' %>>In Progress</option>
                        <option value="resolved" <%= record && record.status === 'resolved' ? 'selected' : '' %>>Resolved</option>
                    </select>
                </div>
                <div class="col-12">
                    <label class="form-label">Issue Description</label>
                    <textarea name="issue_description" class="form-control" rows="3" placeholder="Describe the issue in detail..."><%= record ? record.issue_description : '' %></textarea>
                </div>
                <div class="col-md-4">
                    <label class="form-label">Service Vendor</label>
                    <input type="text" name="vendor" class="form-control" value="<%= record ? record.vendor : '' %>" placeholder="e.g. Dell Support, Local Tech">
                </div>
                <div class="col-md-4">
                    <label class="form-label">Estimated Cost (&#8377;)</label>
                    <div class="input-group"><span class="input-group-text bg-white">&#8377;</span><input type="number" step="0.01" name="cost" class="form-control" value="<%= record ? record.cost : '' %>"></div>
                </div>
                <div class="col-md-4">
                    <label class="form-label">Resolution Date</label>
                    <input type="date" name="resolution_date" class="form-control" value="<%= record ? record.resolution_date : '' %>">
                </div>
                <div class="col-12">
                    <label class="form-label">Remarks</label>
                    <textarea name="remarks" class="form-control" rows="2"><%= record ? record.remarks : '' %></textarea>
                </div>
            </div>
            <div class="mt-4 pt-3 border-top d-flex gap-2">
                <button type="submit" class="btn btn-<%= record ? 'warning' : 'danger' %>"><i class="bi bi-save me-1"></i> <%= record ? 'Update' : 'Log' %> Record</button>
                <a href="/maintenance" class="btn btn-outline-secondary">Cancel</a>
            </div>
        </form>
    </div>
</div>
