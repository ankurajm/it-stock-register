<% title = 'Maintenance #' + record.id %>
<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h4 class="fw-bold mb-0"><i class="bi bi-tools me-2"></i> Maintenance #<%= record.id %></h4>
        <small class="text-muted"><%= record.asset_tag || 'Unknown Item' %></small>
    </div>
    <div class="d-flex gap-2">
        <a href="/maintenance/edit/<%= record.id %>" class="btn btn-warning"><i class="bi bi-pencil"></i> Edit</a>
        <a href="/maintenance" class="btn btn-outline-secondary"><i class="bi bi-arrow-left"></i> Back</a>
    </div>
</div>

<div class="row g-3">
    <div class="col-lg-8">
        <div class="card">
            <div class="card-header"><i class="bi bi-info-circle me-1"></i> Issue Details</div>
            <div class="card-body">
                <div class="row g-3">
                    <div class="col-6 col-md-3"><small class="text-muted d-block">Asset Tag</small><span class="fw-bold"><%= record.asset_tag || '-' %></span></div>
                    <div class="col-6 col-md-3"><small class="text-muted d-block">Category</small><span><%= record.category || '-' %></span></div>
                    <div class="col-6 col-md-3"><small class="text-muted d-block">Brand</small><span><%= record.brand || '-' %></span></div>
                    <div class="col-6 col-md-3"><small class="text-muted d-block">Model</small><span><%= record.model || '-' %></span></div>
                </div>
                <hr>
                <div class="row g-3">
                    <div class="col-12"><small class="text-muted d-block">Issue Description</small><p><%= record.issue_description || 'No description provided' %></p></div>
                    <div class="col-6 col-md-3"><small class="text-muted d-block">Issue Date</small><span><%= record.issue_date %></span></div>
                    <div class="col-6 col-md-3"><small class="text-muted d-block">Vendor</small><span><%= record.vendor || '-' %></span></div>
                    <div class="col-6 col-md-3"><small class="text-muted d-block">Cost</small><span>&#8377;<%= record.cost || '-' %></span></div>
                    <div class="col-6 col-md-3"><small class="text-muted d-block">Status</small>
                        <% if (record.status === 'resolved') { %><span class="badge bg-success">Resolved</span>
                        <% } else if (record.status === 'in-progress') { %><span class="badge bg-info">In Progress</span>
                        <% } else { %><span class="badge bg-danger">Pending</span><% } %>
                    </div>
                    <div class="col-6 col-md-4"><small class="text-muted d-block">Resolution Date</small><span><%= record.resolution_date || '-' %></span></div>
                </div>
                <% if (record.remarks) { %>
                <hr>
                <div class="col-12"><small class="text-muted d-block">Remarks</small><p><%= record.remarks %></p></div>
                <% } %>
            </div>
        </div>
    </div>
    <div class="col-lg-4">
        <div class="card mb-3">
            <div class="card-header"><i class="bi bi-clock me-1"></i> Timeline</div>
            <div class="card-body">
                <div class="d-flex mb-2"><div class="me-3 text-success"><i class="bi bi-record-circle"></i></div><div><small class="d-block text-muted">Issue Reported</small><strong><%= record.issue_date %></strong></div></div>
                <% if (record.status === 'resolved') { %>
                <div class="d-flex mb-2"><div class="me-3 text-info"><i class="bi bi-record-circle"></i></div><div><small class="d-block text-muted">Resolved On</small><strong><%= record.resolution_date %></strong></div></div>
                <% } %>
                <div class="d-flex"><div class="me-3"><i class="bi bi-circle"></i></div><div><small class="d-block text-muted">Days Open</small><strong>
                    <% 
                    const start = new Date(record.issue_date);
                    const end = record.resolution_date ? new Date(record.resolution_date) : new Date();
                    const days = Math.ceil((end - start) / (1000*60*60*24));
                    %><%= days %> day(s)
                </strong></div></div>
            </div>
        </div>
        <% if (record.status !== 'resolved') { %>
        <div class="card border-success">
            <div class="card-body text-center">
                <p class="mb-2">Mark this issue as resolved?</p>
                <form method="POST" action="/maintenance/<%= record.id %>/resolve">
                    <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                    <input type="hidden" name="resolution_date" value="<%= new Date().toISOString().split('T')[0] %>">
                    <button type="submit" class="btn btn-success w-100"><i class="bi bi-check-lg"></i> Mark Resolved</button>
                </form>
            </div>
        </div>
        <% } %>
    </div>
</div>
