<% title = employee.name + ' - Allocation History' %>
<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h4 class="fw-bold mb-0"><i class="bi bi-clock-history me-2"></i> <%= employee.name %></h4>
        <small class="text-muted"><%= employee.emp_id %> &middot; Complete Allocation History</small>
    </div>
    <a href="/employees/view/<%= employee.id %>" class="btn btn-outline-secondary"><i class="bi bi-arrow-left"></i> Back</a>
</div>

<div class="card mb-4">
    <div class="card-body">
        <div class="row">
            <div class="col-4"><small class="text-muted d-block">Employee ID</small><span class="fw-bold"><%= employee.emp_id %></span></div>
            <div class="col-4"><small class="text-muted d-block">Department</small><span><%= employee.department || '-' %></span></div>
            <div class="col-4"><small class="text-muted d-block">Total Allocations</small><span class="badge bg-info fs-6"><%= allocations.length %></span></div>
        </div>
    </div>
</div>

<div class="card">
    <div class="table-responsive">
        <table class="table table-hover mb-0">
            <thead class="table-light"><tr><th>Asset Tag</th><th>Category</th><th>Brand / Model</th><th>Allocated</th><th>Returned</th><th>Remarks</th><th>Status</th></tr></thead>
            <tbody>
                <% if (allocations.length === 0) { %>
                <tr><td colspan="7" class="text-center text-muted py-5"><i class="bi bi-inbox fs-3 d-block mb-2"></i> No allocation history</td></tr>
                <% } %>
                <% allocations.forEach(a => { %>
                <tr>
                    <td class="fw-medium"><%= a.asset_tag || '-' %></td>
                    <td><%= a.category || '-' %></td>
                    <td><%= a.brand || '' %> <%= a.model || '' %></td>
                    <td><%= a.allocated_date %></td>
                    <td><%= a.return_date || '-' %></td>
                    <td><%= a.remarks || '-' %></td>
                    <td><span class="badge bg-<%= a.status === 'active' ? 'warning text-dark' : 'success' %>"><%= a.status %></span></td>
                </tr>
                <% }); %>
            </tbody>
        </table>
    </div>
</div>
