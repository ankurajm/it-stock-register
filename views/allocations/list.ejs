<% title = 'Allocations' %>
<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h4 class="fw-bold mb-0"><i class="bi bi-arrow-left-right me-2"></i> Allocations</h4>
        <small class="text-muted"><%= typeof totalItems !== 'undefined' ? totalItems : allocations.length %> record(s)</small>
    </div>
    <a href="/allocations/allocate" class="btn btn-warning"><i class="bi bi-plus-lg"></i> New Allocation</a>
</div>

<div class="card mb-4">
    <div class="card-body">
        <form method="GET" class="row g-2">
            <div class="col-md-6">
                <div class="input-group"><span class="input-group-text bg-white"><i class="bi bi-search"></i></span>
                    <input type="text" name="search" class="form-control" placeholder="Search asset tag or employee..." value="<%= search || '' %>">
                </div>
            </div>
            <div class="col-md-3">
                <select name="status" class="form-select">
                    <option value="">All Status</option>
                    <option value="active" <%= status === 'active' ? 'selected' : '' %>>Active</option>
                    <option value="returned" <%= status === 'returned' ? 'selected' : '' %>>Returned</option>
                </select>
            </div>
            <div class="col-md-3">
                <button type="submit" class="btn btn-primary w-100"><i class="bi bi-funnel"></i> Filter</button>
            </div>
        </form>
    </div>
</div>

<div class="card">
    <div class="table-responsive">
        <table class="table table-hover mb-0">
            <thead class="table-light">
                <tr><th>Asset Tag</th><th>Employee</th><th>Department</th><th>Allocated</th><th>Returned</th><th>Status</th><th class="text-end">Actions</th></tr>
            </thead>
            <tbody>
                <% if (allocations.length === 0) { %>
                <tr><td colspan="7" class="text-center text-muted py-5"><i class="bi bi-inbox fs-3 d-block mb-2"></i> No allocations found</td></tr>
                <% } %>
                <% allocations.forEach(a => { %>
                <tr>
                    <td class="fw-medium"><%= a.asset_tag || '-' %></td>
                    <td><%= a.emp_name || '-' %></td>
                    <td><%= a.department || '-' %></td>
                    <td><%= a.allocated_date %></td>
                    <td><%= a.return_date || '-' %></td>
                    <td><span class="badge bg-<%= a.status === 'active' ? 'warning text-dark' : 'success' %>"><%= a.status %></span></td>
                    <td class="text-end">
                        <% if (a.status === 'active') { %>
                        <button type="button" class="btn btn-sm btn-success" data-bs-toggle="modal" data-bs-target="#returnModal<%= a.id %>"><i class="bi bi-arrow-return-left"></i> Return</button>
                        <div class="modal fade" id="returnModal<%= a.id %>" tabindex="-1">
                            <div class="modal-dialog modal-sm">
                                <div class="modal-content">
                                    <form method="POST" action="/allocations/return/<%= a.id %>">
                                        <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                                        <div class="modal-header"><h6 class="modal-title">Return Item</h6><button type="button" class="btn-close" data-bs-dismiss="modal"></button></div>
                                        <div class="modal-body">
                                            <p class="mb-1"><strong><%= a.asset_tag %></strong></p>
                                            <small class="text-muted">Allocated to <%= a.emp_name %> on <%= a.allocated_date %></small>
                                            <div class="mt-3 mb-3">
                                                <label class="form-label">Return Date</label>
                                                <input type="date" name="return_date" class="form-control" value="<%= new Date().toISOString().split('T')[0] %>" required>
                                            </div>
                                            <div class="mb-3">
                                                <label class="form-label">Remarks</label>
                                                <textarea name="remarks" class="form-control" rows="2" placeholder="Condition on return..."></textarea>
                                            </div>
                                        </div>
                                        <div class="modal-footer">
                                            <button type="button" class="btn btn-sm btn-secondary" data-bs-dismiss="modal">Cancel</button>
                                            <button type="submit" class="btn btn-sm btn-success">Confirm Return</button>
                                        </div>
                                    </form>
                                </div>
                            </div>
                        </div>
                        <% } else { %>
                        <span class="text-muted small">Completed</span>
                        <% } %>
                    </td>
                </tr>
                <% }); %>
            </tbody>
        </table>
    </div>
    <% if (typeof totalPages !== 'undefined' && totalPages > 1) { %>
    <div class="card-footer bg-white d-flex justify-content-between align-items-center">
        <small class="text-muted">Page <%= currentPage %> of <%= totalPages %> (<%= totalItems %> records)</small>
        <nav>
            <ul class="pagination pagination-sm mb-0">
                <li class="page-item <%= currentPage <= 1 ? 'disabled' : '' %>">
                    <a class="page-link" href="?page=<%= currentPage - 1 %><%= search ? '&search=' + encodeURIComponent(search) : '' %><%= status ? '&status=' + encodeURIComponent(status) : '' %>">Previous</a>
                </li>
                <% for (let p = Math.max(1, currentPage - 2); p <= Math.min(totalPages, currentPage + 2); p++) { %>
                <li class="page-item <%= p === currentPage ? 'active' : '' %>">
                    <a class="page-link" href="?page=<%= p %><%= search ? '&search=' + encodeURIComponent(search) : '' %><%= status ? '&status=' + encodeURIComponent(status) : '' %>"><%= p %></a>
                </li>
                <% } %>
                <li class="page-item <%= currentPage >= totalPages ? 'disabled' : '' %>">
                    <a class="page-link" href="?page=<%= currentPage + 1 %><%= search ? '&search=' + encodeURIComponent(search) : '' %><%= status ? '&status=' + encodeURIComponent(status) : '' %>">Next</a>
                </li>
            </ul>
        </nav>
    </div>
    <% } %>
</div>
