<% title = 'Activity Log' %>
<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h4 class="fw-bold mb-0"><i class="bi bi-clock-history me-2"></i> Activity Log</h4>
        <small class="text-muted"><%= totalLogs %> event(s) recorded</small>
    </div>
    <a href="/logs/export<%= eventType ? '?event_type=' + eventType : '' %><%= startDate ? '&start_date=' + startDate : '' %><%= endDate ? '&end_date=' + endDate : '' %>" class="btn btn-outline-success" target="_blank">
        <i class="bi bi-file-earmark-excel"></i> Export Excel
    </a>
</div>

<div class="card mb-4">
    <div class="card-body">
        <form method="GET" class="row g-2">
            <div class="col-md-3">
                <select name="event_type" class="form-select">
                    <option value="">All Events</option>
                    <option value="login_success" <%= eventType === 'login_success' ? 'selected' : '' %>>Login Success</option>
                    <option value="login_failed" <%= eventType === 'login_failed' ? 'selected' : '' %>>Login Failed</option>
                    <option value="admin_login_success" <%= eventType === 'admin_login_success' ? 'selected' : '' %>>Admin Login Success</option>
                    <option value="admin_login_failed" <%= eventType === 'admin_login_failed' ? 'selected' : '' %>>Admin Login Failed</option>
                    <option value="logout" <%= eventType === 'logout' ? 'selected' : '' %>>Logout</option>
                    <option value="password_change" <%= eventType === 'password_change' ? 'selected' : '' %>>Password Change</option>
                </select>
            </div>
            <div class="col-md-3">
                <input type="date" name="start_date" class="form-control" value="<%= startDate || '' %>" placeholder="From date">
            </div>
            <div class="col-md-3">
                <input type="date" name="end_date" class="form-control" value="<%= endDate || '' %>" placeholder="To date">
            </div>
            <div class="col-md-3 d-flex gap-2">
                <button type="submit" class="btn btn-primary"><i class="bi bi-funnel"></i> Filter</button>
                <a href="/logs" class="btn btn-outline-secondary">Clear</a>
            </div>
        </form>
    </div>
</div>

<div class="card">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover mb-0">
                <thead class="table-light">
                    <tr>
                        <th>Date & Time</th>
                        <th>User</th>
                        <th>Event</th>
                        <th>IP Address</th>
                        <th>User Agent</th>
                    </tr>
                </thead>
                <tbody>
                    <% if (logs.length === 0) { %>
                    <tr><td colspan="5" class="text-center text-muted py-4">No activity logs found</td></tr>
                    <% } else { %>
                    <% logs.forEach(log => { %>
                    <tr>
                        <td><small><%= new Date(log.created_at).toLocaleString('en-IN', { timeZone: 'Asia/Kolkata' }) %></small></td>
                        <td><strong><%= log.username || '-' %></strong></td>
                        <td>
                            <% if (log.event_type.includes('success')) { %>
                                <span class="badge bg-success"><i class="bi bi-check-circle"></i> <%= log.event_type.replace(/_/g, ' ').replace(/\b\w/g, c => c.toUpperCase()) %></span>
                            <% } else if (log.event_type.includes('failed')) { %>
                                <span class="badge bg-danger"><i class="bi bi-x-circle"></i> <%= log.event_type.replace(/_/g, ' ').replace(/\b\w/g, c => c.toUpperCase()) %></span>
                            <% } else if (log.event_type === 'logout') { %>
                                <span class="badge bg-warning text-dark"><i class="bi bi-box-arrow-right"></i> Logout</span>
                            <% } else { %>
                                <span class="badge bg-info"><i class="bi bi-info-circle"></i> <%= log.event_type.replace(/_/g, ' ').replace(/\b\w/g, c => c.toUpperCase()) %></span>
                            <% } %>
                        </td>
                        <td><small class="text-muted"><%= log.ip_address || '-' %></small></td>
                        <td><small class="text-muted text-truncate" style="max-width:200px" title="<%= log.user_agent %>"><%= log.user_agent || '-' %></small></td>
                    </tr>
                    <% }); %>
                    <% } %>
                </tbody>
            </table>
        </div>
    </div>
</div>

<% if (totalPages > 1) { %>
<nav class="mt-3">
    <ul class="pagination justify-content-center">
        <% for (let i = 1; i <= totalPages; i++) { %>
        <li class="page-item <%= i === currentPage ? 'active' : '' %>">
            <a class="page-link" href="/logs?page=<%= i %>&event_type=<%= eventType || '' %>&start_date=<%= startDate || '' %>&end_date=<%= endDate || '' %>"><%= i %></a>
        </li>
        <% } %>
    </ul>
</nav>
<% } %>
