<% title = 'Items' %>
<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h4 class="fw-bold mb-0"><i class="bi bi-laptop me-2"></i> IT Items</h4>
        <small class="text-muted"><%= totalItems %> item(s) found</small>
    </div>
    <div class="d-flex gap-2">
        <a href="/reports/items/pdf" class="btn btn-sm btn-outline-danger"><i class="bi bi-file-earmark-pdf"></i> PDF</a>
        <a href="/reports/items/excel" class="btn btn-sm btn-outline-success"><i class="bi bi-file-earmark-excel"></i> Excel</a>
        <a href="/bulk/items" class="btn btn-sm btn-outline-info"><i class="bi bi-upload"></i> Bulk Import</a>
        <a href="/items/add" class="btn btn-primary"><i class="bi bi-plus-lg"></i> Add Item</a>
        <% if (typeof user !== 'undefined' && user && user.role === 'admin' && totalItems === 0) { %>
        <form method="POST" action="/items/seed-sample" style="display:inline">
            <input type="hidden" name="_csrf" value="<%= csrfToken %>">
            <button type="submit" class="btn btn-sm btn-outline-warning"><i class="bi bi-flask"></i> Add Sample Items</button>
        </form>
        <% } %>
    </div>
</div>

<div class="card mb-4">
    <div class="card-body">
        <form method="GET" class="row g-2">
            <div class="col-12 col-md-4">
                <div class="input-group">
                    <span class="input-group-text bg-white"><i class="bi bi-search"></i></span>
                    <input type="text" name="search" class="form-control" placeholder="Search asset tag, brand, model, serial..." value="<%= search || '' %>">
                </div>
            </div>
            <div class="col-6 col-md-2">
                <select name="category" class="form-select">
                    <option value="">All Categories</option>
                    <% if (typeof categories !== 'undefined') { categories.forEach(c => { %>
                    <option value="<%= c.name %>" <%= category === c.name ? 'selected' : '' %>><%= c.name %></option>
                    <% }); } %>
                </select>
            </div>
            <div class="col-6 col-md-2">
                <select name="status" class="form-select">
                    <option value="">All Status</option>
                    <option value="available" <%= status === 'available' ? 'selected' : '' %>>Available</option>
                    <option value="allocated" <%= status === 'allocated' ? 'selected' : '' %>>Allocated</option>
                    <option value="fixed" <%= status === 'fixed' ? 'selected' : '' %>>Fixed (Permanent)</option>
                    <option value="maintenance" <%= status === 'maintenance' ? 'selected' : '' %>>Maintenance</option>
                    <option value="disposed" <%= status === 'disposed' ? 'selected' : '' %>>Disposed</option>
                </select>
            </div>
            <div class="col-6 col-md-2">
                <select name="condition" class="form-select">
                    <option value="">All Condition</option>
                    <option value="new" <%= condition === 'new' ? 'selected' : '' %>>New</option>
                    <option value="good" <%= condition === 'good' ? 'selected' : '' %>>Good</option>
                    <option value="fair" <%= condition === 'fair' ? 'selected' : '' %>>Fair</option>
                    <option value="poor" <%= condition === 'poor' ? 'selected' : '' %>>Poor</option>
                </select>
            </div>
            <div class="col-6 col-md-2">
                <button type="submit" class="btn btn-primary w-100"><i class="bi bi-funnel"></i> Filter</button>
            </div>
        </form>
    </div>
</div>

<div class="card">
    <div class="table-responsive">
        <table class="table table-hover mb-0">
            <thead class="table-light">
                <tr>
                    <th>Asset Tag</th>
                    <th>Category</th>
                    <th>Brand / Model</th>
                    <th class="d-none d-lg-table-cell">Serial No.</th>
                    <th class="d-none d-md-table-cell">Purchase</th>
                    <th class="d-none d-md-table-cell">Warranty</th>
                    <th>Status</th>
                    <th class="text-end">Actions</th>
                </tr>
            </thead>
            <tbody>
                <% if (items.length === 0) { %>
                <tr><td colspan="8" class="text-center text-muted py-5"><i class="bi bi-inbox fs-3 d-block mb-2"></i> No items found</td></tr>
                <% } %>
                <% items.forEach(item => { 
                    const isExpiring = item.warranty_end && new Date(item.warranty_end).getTime() && new Date(item.warranty_end) <= new Date(Date.now() + 30*24*60*60*1000);
                %>
                <tr>
                    <td class="fw-medium"><%= item.asset_tag %></td>
                    <td><span class="badge bg-secondary"><%= item.category %></span></td>
                    <td><%= item.brand || '' %> <%= item.model || '' %></td>
                    <td class="d-none d-lg-table-cell"><code><%= item.serial_number || '-' %></code></td>
                    <td class="d-none d-md-table-cell"><%= item.purchase_date || '-' %></td>
                    <td class="d-none d-md-table-cell">
                        <span class="<%= isExpiring ? 'text-danger fw-bold' : '' %>"><%= item.warranty_end || '-' %></span>
                    </td>
                    <td>
                        <% if (item.status === 'available') { %><span class="badge bg-success">Available</span>
                        <% } else if (item.status === 'allocated') { %><span class="badge bg-warning text-dark">Allocated</span>
                        <% } else if (item.status === 'fixed') { %><span class="badge bg-info">Fixed</span>
                        <% } else if (item.status === 'maintenance') { %><span class="badge bg-danger">Maintenance</span>
                        <% } else if (item.status === 'disposed') { %><span class="badge bg-dark">Disposed</span>
                        <% } else { %><span class="badge bg-secondary"><%= item.status %></span><% } %>
                    </td>
                    <td class="text-end">
                        <div class="btn-group btn-group-sm">
                            <a href="/items/view/<%= item.id %>" class="btn btn-outline-info" title="View"><i class="bi bi-eye"></i></a>
                            <a href="/items/edit/<%= item.id %>" class="btn btn-outline-warning" title="Edit"><i class="bi bi-pencil"></i></a>
                            <form method="POST" action="/items/delete/<%= item.id %>" style="display:inline" onsubmit="return confirm('Delete item <%= item.asset_tag %>?')">
                                <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                                <button type="submit" class="btn btn-outline-danger" title="Delete"><i class="bi bi-trash"></i></button>
                            </form>
                        </div>
                    </td>
                </tr>
                <% }); %>
            </tbody>
        </table>
    </div>
    <% if (typeof totalPages !== 'undefined' && totalPages > 1) { %>
    <div class="card-footer bg-white d-flex justify-content-between align-items-center">
        <small class="text-muted">Page <%= currentPage %> of <%= totalPages %> (<%= totalItems %> items)</small>
        <nav>
            <ul class="pagination pagination-sm mb-0">
                <li class="page-item <%= currentPage <= 1 ? 'disabled' : '' %>">
                    <a class="page-link" href="?page=<%= currentPage - 1 %><%= search ? '&search=' + encodeURIComponent(search) : '' %><%= category ? '&category=' + encodeURIComponent(category) : '' %><%= status ? '&status=' + encodeURIComponent(status) : '' %><%= condition ? '&condition=' + encodeURIComponent(condition) : '' %>">Previous</a>
                </li>
                <% for (let p = Math.max(1, currentPage - 2); p <= Math.min(totalPages, currentPage + 2); p++) { %>
                <li class="page-item <%= p === currentPage ? 'active' : '' %>">
                    <a class="page-link" href="?page=<%= p %><%= search ? '&search=' + encodeURIComponent(search) : '' %><%= category ? '&category=' + encodeURIComponent(category) : '' %><%= status ? '&status=' + encodeURIComponent(status) : '' %><%= condition ? '&condition=' + encodeURIComponent(condition) : '' %>"><%= p %></a>
                </li>
                <% } %>
                <li class="page-item <%= currentPage >= totalPages ? 'disabled' : '' %>">
                    <a class="page-link" href="?page=<%= currentPage + 1 %><%= search ? '&search=' + encodeURIComponent(search) : '' %><%= category ? '&category=' + encodeURIComponent(category) : '' %><%= status ? '&status=' + encodeURIComponent(status) : '' %><%= condition ? '&condition=' + encodeURIComponent(condition) : '' %>">Next</a>
                </li>
            </ul>
        </nav>
    </div>
    <% } %>
</div>
