<% title = 'Bulk Purchase Clone' %>
<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h4 class="fw-bold mb-0"><i class="bi bi-copy me-2"></i> Bulk Purchase / Clone Items</h4>
        <small class="text-muted">Create multiple items with same configuration, unique serial numbers &amp; QR codes</small>
    </div>
    <a href="/items" class="btn btn-outline-secondary"><i class="bi bi-arrow-left"></i> Back</a>
</div>

<% if (error) { %>
<div class="alert alert-danger alert-dismissible fade show border-start border-danger border-4"><i class="bi bi-exclamation-triangle me-2"></i> <%= error %><button type="button" class="btn-close" data-bs-dismiss="alert"></button></div>
<% } %>

<div class="card">
    <div class="card-body p-4">
        <form method="POST" action="/items/bulk-clone">
            <input type="hidden" name="_csrf" value="<%= csrfToken %>">
            <div class="row g-3">
                <div class="col-md-4">
                    <label class="form-label">Category <span class="text-danger">*</span></label>
                    <select name="category" class="form-select" required>
                        <option value="">Select...</option>
                        <% categories.forEach(c => { %>
                        <option value="<%= c.id %>"><%= c.name %> (<%= c.prefix %>-XXXX)</option>
                        <% }); %>
                    </select>
                    <div class="form-text">Asset tags auto-generated as PREFIX-0001, PREFIX-0002, etc.</div>
                </div>
                <div class="col-md-4">
                    <label class="form-label">Brand</label>
                    <input type="text" name="brand" class="form-control" placeholder="e.g. Dell, HP">
                </div>
                <div class="col-md-4">
                    <label class="form-label">Model</label>
                    <input type="text" name="model" class="form-control" placeholder="e.g. Latitude 3420">
                </div>
                <div class="col-12">
                    <label class="form-label">Specifications (shared)</label>
                    <textarea name="specifications" class="form-control" rows="2" placeholder="RAM: 8GB, Storage: 256GB SSD, Processor: i5..."></textarea>
                </div>
                <div class="col-md-3">
                    <label class="form-label">Purchase Date</label>
                    <input type="date" name="purchase_date" class="form-control" value="<%= new Date().toISOString().split('T')[0] %>">
                </div>
                <div class="col-md-3">
                    <label class="form-label">Purchase Price (&#8377;)</label>
                    <div class="input-group"><span class="input-group-text bg-white">&#8377;</span><input type="number" step="0.01" name="purchase_price" class="form-control"></div>
                </div>
                <div class="col-md-3">
                    <label class="form-label">Vendor</label>
                    <input type="text" name="vendor" class="form-control">
                </div>
                <div class="col-md-3">
                    <label class="form-label">Warranty End</label>
                    <input type="date" name="warranty_end" class="form-control">
                </div>
                <div class="col-md-3">
                    <label class="form-label">Condition</label>
                    <select name="condition" class="form-select">
                        <option value="new">New</option>
                        <option value="good">Good</option>
                        <option value="fair">Fair</option>
                        <option value="poor">Poor</option>
                    </select>
                </div>
                <div class="col-md-3">
                    <label class="form-label">Location</label>
                    <input type="text" name="location" class="form-control" placeholder="Floor 3, Room 301">
                </div>
                <div class="col-12">
                    <label class="form-label">Notes</label>
                    <textarea name="notes" class="form-control" rows="2"></textarea>
                </div>
                <div class="col-12">
                    <label class="form-label">Serial Numbers <span class="text-danger">*</span></label>
                    <textarea name="serial_numbers" class="form-control" rows="5" placeholder="Enter one serial number per line. QR codes will be generated for each." required></textarea>
                    <div class="form-text">One serial number per line. Each gets a unique asset tag and QR code.</div>
                </div>
            </div>
            <div class="mt-4 pt-3 border-top d-flex gap-2">
                <button type="submit" class="btn btn-success"><i class="bi bi-copy me-1"></i> Generate Items</button>
                <a href="/items" class="btn btn-outline-secondary">Cancel</a>
            </div>
        </form>
    </div>
</div>
