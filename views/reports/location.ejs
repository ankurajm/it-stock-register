<% title = 'Location-wise Reports' %>
<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h4 class="fw-bold mb-0"><i class="bi bi-geo-alt me-2"></i> Location-wise Reports</h4>
        <small class="text-muted"><%= locations.length %> location(s) found</small>
    </div>
    <div class="d-flex gap-2">
        <a href="/reports/locations/pdf" class="btn btn-outline-danger" target="_blank"><i class="bi bi-file-earmark-pdf"></i> Summary PDF</a>
        <a href="/reports/locations/excel" class="btn btn-outline-success" target="_blank"><i class="bi bi-file-earmark-excel"></i> Summary Excel</a>
    </div>
</div>

<div class="row">
    <% if (locations.length === 0) { %>
    <div class="col-12">
        <div class="card">
            <div class="card-body text-center text-muted py-5">
                <i class="bi bi-geo-alt fs-1"></i>
                <p class="mt-2">No locations found. Add items with location details first.</p>
            </div>
        </div>
    </div>
    <% } else { %>
    <% locations.forEach(loc => { %>
    <div class="col-md-6 col-lg-4 mb-4">
        <div class="card h-100 border-top border-success border-3">
            <div class="card-body">
                <h5 class="card-title fw-bold"><i class="bi bi-geo-alt me-2 text-success"></i><%= loc.location %></h5>
                <div class="row text-center mt-3">
                    <div class="col-3">
                        <div class="fs-4 fw-bold text-primary"><%= loc.total_items %></div>
                        <small class="text-muted">Total</small>
                    </div>
                    <div class="col-3">
                        <div class="fs-4 fw-bold text-success"><%= loc.available %></div>
                        <small class="text-muted">Available</small>
                    </div>
                    <div class="col-3">
                        <div class="fs-4 fw-bold text-warning"><%= loc.allocated %></div>
                        <small class="text-muted">Allocated</small>
                    </div>
                    <div class="col-3">
                        <div class="fs-4 fw-bold text-info"><%= loc.fixed_count %></div>
                        <small class="text-muted">Fixed</small>
                    </div>
                </div>
            </div>
            <div class="card-footer bg-white d-flex gap-2">
                <a href="/reports/locations/<%= encodeURIComponent(loc.location) %>/pdf" class="btn btn-sm btn-outline-danger flex-fill" target="_blank">
                    <i class="bi bi-file-earmark-pdf"></i> PDF
                </a>
                <a href="/reports/locations/<%= encodeURIComponent(loc.location) %>/excel" class="btn btn-sm btn-outline-success flex-fill" target="_blank">
                    <i class="bi bi-file-earmark-excel"></i> Excel
                </a>
            </div>
        </div>
    </div>
    <% }); %>
    <% } %>
</div>
