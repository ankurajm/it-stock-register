<% title = 'No Dues Certificate' %>
<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h4 class="fw-bold mb-0"><i class="bi bi-file-earmark-pdf me-2"></i> No Dues Certificate</h4>
        <small class="text-muted">Generate no-dues certificate for an employee after clearing all items</small>
    </div>
    <a href="/reports" class="btn btn-outline-secondary"><i class="bi bi-arrow-left"></i> Back to Reports</a>
</div>

<div class="card">
    <div class="card-body p-4">
        <h5 class="fw-semibold mb-3">Select Employee</h5>
        <p class="text-muted small mb-3">Choose an employee to generate a no-dues certificate. This certifies that all IT assets have been returned and accounted for.</p>

        <form method="GET" action="" id="noDuesForm">
            <div class="mb-3">
                <label for="employee" class="form-label">Employee <span class="text-danger">*</span></label>
                <select name="employee" id="employee" class="form-select" required>
                    <option value="">-- Select Employee --</option>
                    <% employees.forEach(e => { %>
                    <option value="<%= e.emp_id %>"><%= e.name %> (<%= e.emp_id %>) <%= e.department ? '- ' + e.department : '' %></option>
                    <% }); %>
                </select>
            </div>
            <button type="submit" class="btn btn-danger"><i class="bi bi-file-earmark-pdf me-1"></i> Generate No Dues Certificate</button>
        </form>
    </div>
</div>

<script>
document.getElementById('noDuesForm').addEventListener('submit', function(e) {
    e.preventDefault();
    const empId = document.getElementById('employee').value;
    if (!empId) return;
    window.open('/reports/no-dues/' + encodeURIComponent(empId) + '/pdf', '_blank');
});
</script>