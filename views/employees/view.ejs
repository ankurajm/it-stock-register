<% title = employee.name %>
<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h4 class="fw-bold mb-0"><i class="bi bi-person me-2"></i> <%= employee.name %></h4>
        <small class="text-muted"><%= employee.username %> &middot; <%= employee.department || 'N/A' %></small>
    </div>
    <div class="d-flex gap-2">
        <a href="/employees/edit/<%= employee.id %>" class="btn btn-warning"><i class="bi bi-pencil"></i> Edit</a>
        <a href="/allocations/employee/<%= employee.id %>/history" class="btn btn-outline-info"><i class="bi bi-clock-history"></i> Full History</a>
        <a href="/employees" class="btn btn-outline-secondary"><i class="bi bi-arrow-left"></i> Back</a>
    </div>
</div>

<div class="row g-3 mb-4">
    <div class="col-md-8">
        <div class="card h-100">
            <div class="card-header"><i class="bi bi-person-badge me-1"></i> Employee Details</div>
            <div class="card-body">
                <div class="row g-3">
                    <div class="col-6 col-md-3"><small class="text-muted d-block">Employee ID</small><span class="fw-bold"><%= employee.username %></span></div>
                    <div class="col-6 col-md-3"><small class="text-muted d-block">Department</small><span><%= employee.department || '-' %></span></div>
                    <div class="col-6 col-md-3"><small class="text-muted d-block">Designation</small><span><%= employee.designation || '-' %></span></div>
                    <div class="col-6 col-md-3"><small class="text-muted d-block">Status</small><span class="badge bg-<%= employee.status === 'active' ? 'success' : 'secondary' %>"><%= employee.status %></span></div>
                    <div class="col-6 col-md-4"><small class="text-muted d-block">Email</small><span><%= employee.email || '-' %></span></div>
                    <div class="col-6 col-md-4"><small class="text-muted d-block">Phone</small><span><%= employee.phone || '-' %></span></div>
                    <div class="col-6 col-md-4"><small class="text-muted d-block">Joining Date</small><span><%= employee.joining_date || '-' %></span></div>
                    <% if (employee.class_teacher) { %>
                    <div class="col-6 col-md-4"><small class="text-muted d-block">Class Teacher</small><span><%= employee.class_teacher %></span></div>
                    <% } %>
                    <% if (employee.subject_teacher) { %>
                    <div class="col-6 col-md-4"><small class="text-muted d-block">Subject Teacher</small><span><%= employee.subject_teacher %></span></div>
                    <% } %>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card h-100">
            <div class="card-header"><i class="bi bi-bar-chart me-1"></i> Summary</div>
            <div class="card-body">
                <div class="text-center py-2">
                    <div class="display-5 fw-bold text-primary"><%= allocations.filter(a => a.status === 'active').length %></div>
                    <small class="text-muted">Currently Allocated Items</small>
                </div>
                <div class="text-center py-2">
                    <div class="display-5 fw-bold text-secondary"><%= allocations.length %></div>
                    <small class="text-muted">Total Allocations</small>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="card">
    <div class="card-header d-flex justify-content-between align-items-center">
        <span><i class="bi bi-arrow-left-right me-1"></i> Allocation History</span>
        <a href="/allocations/employee/<%= employee.id %>/history" class="btn btn-sm btn-outline-info">View Full History</a>
    </div>
    <div class="table-responsive">
        <table class="table table-hover mb-0">
            <thead class="table-light"><tr><th>Asset Tag</th><th>Category</th><th>Allocated</th><th>Returned</th><th>Status</th></tr></thead>
            <tbody>
                <% if (allocations.length === 0) { %>
                <tr><td colspan="5" class="text-center text-muted py-4">No allocations yet</td></tr>
                <% } %>
                <% allocations.forEach(a => { %>
                <tr>
                    <td class="fw-medium"><%= a.asset_tag || '-' %></td>
                    <td><%= a.category || '-' %></td>
                    <td><%= a.allocated_date %></td>
                    <td><%= a.return_date || '-' %></td>
                    <td><span class="badge bg-<%= a.status === 'active' ? 'warning text-dark' : 'success' %>"><%= a.status %></span></td>
                </tr>
                <% }); %>
            </tbody>
        </table>
    </div>
</div>
