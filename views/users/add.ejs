<% title = editUser ? 'Edit ' + editUser.username : 'Add User' %>
<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h4 class="fw-bold mb-0"><i class="bi bi-<%= editUser ? 'pencil' : 'plus' %>-circle me-2"></i> <%= editUser ? 'Edit' : 'Add' %> User</h4>
        <small class="text-muted"><%= editUser ? 'Update user details' : 'Create a new system user' %></small>
    </div>
    <a href="/users" class="btn btn-outline-secondary"><i class="bi bi-arrow-left"></i> Back</a>
</div>

<% if (error) { %>
<div class="alert alert-danger alert-dismissible fade show border-start border-danger border-4"><i class="bi bi-exclamation-triangle me-2"></i> <%= error %><button type="button" class="btn-close" data-bs-dismiss="alert"></button></div>
<% } %>

<div class="card">
    <div class="card-body p-4">
        <form method="POST" action="<%= editUser ? '/users/edit/' + editUser.id : '/users/add' %>">
            <input type="hidden" name="_csrf" value="<%= csrfToken %>">
            <div class="row g-3">
                <div class="col-md-4">
                    <label class="form-label">Username <span class="text-danger">*</span></label>
                    <input type="text" name="username" class="form-control" value="<%= editUser ? editUser.username : '' %>" <%= editUser ? 'readonly' : 'required' %>>
                </div>
                <% if (!editUser) { %>
                <div class="col-md-4">
                    <label class="form-label">Password <span class="text-danger">*</span></label>
                    <input type="password" name="password" class="form-control" required minlength="4">
                </div>
                <% } %>
                <div class="col-md-4">
                    <label class="form-label">Initials</label>
                    <input type="text" name="initials" class="form-control" value="<%= editUser ? editUser.initials : '' %>" placeholder="e.g. JD" maxlength="10">
                </div>
                <div class="col-md-4">
                    <label class="form-label">Role</label>
                    <select name="role" class="form-select">
                        <option value="user" <%= editUser && editUser.role === 'user' ? 'selected' : '' %>>User</option>
                        <option value="admin" <%= editUser && editUser.role === 'admin' ? 'selected' : '' %>>Admin</option>
                    </select>
                </div>
            </div>
            <div class="mt-4 pt-3 border-top d-flex gap-2">
                <button type="submit" class="btn btn-primary"><i class="bi bi-save me-1"></i> <%= editUser ? 'Update' : 'Save' %> User</button>
                <a href="/users" class="btn btn-outline-secondary">Cancel</a>
            </div>
        </form>
    </div>
</div>
