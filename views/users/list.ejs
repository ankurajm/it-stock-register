<% title = 'Users' %>
<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h4 class="fw-bold mb-0"><i class="bi bi-people me-2"></i> System Users</h4>
        <small class="text-muted">Manage application users</small>
    </div>
    <div class="d-flex gap-2">
        <a href="/bulk/users" class="btn btn-outline-primary"><i class="bi bi-upload"></i> Bulk Import</a>
        <a href="/users/add" class="btn btn-primary"><i class="bi bi-plus-lg"></i> Add User</a>
    </div>
</div>

<div class="card">
    <form method="POST" action="/users/bulk-delete" id="bulkDeleteForm">
        <input type="hidden" name="_csrf" value="<%= csrfToken %>">
        <div class="table-responsive">
            <table class="table table-hover mb-0">
                <thead class="table-light">
                    <tr><th width="40"><input type="checkbox" id="selectAll" class="form-check-input"></th><th>Username</th><th>Initials</th><th>Role</th><th>Created</th><th>Password Request</th><th class="text-end">Actions</th></tr>
                </thead>
                <tbody>
                    <% if (users.length === 0) { %>
                    <tr><td colspan="7" class="text-center text-muted py-5"><i class="bi bi-people fs-3 d-block mb-2"></i> No users</td></tr>
                    <% } %>
                    <% users.forEach(u => { %>
                    <tr>
                        <td><input type="checkbox" name="user_ids[]" value="<%= u.id %>" class="form-check-input user-checkbox" <%= u.id === user.id ? 'disabled' : '' %>></td>
                        <td class="fw-medium"><%= u.username %></td>
                        <td><%= u.initials || '-' %></td>
                        <td><span class="badge bg-<%= u.role === 'admin' ? 'danger' : 'primary' %>"><%= u.role %></span></td>
                        <td><%= u.created_at %></td>
                        <td>
                            <% if (u.password_change_requested) { %>
                            <span class="badge bg-warning text-dark">Requested</span>
                            <% } else { %>
                            <span class="text-muted">-</span>
                            <% } %>
                        </td>
                        <td class="text-end">
                            <div class="btn-group btn-group-sm">
                                <a href="/users/edit/<%= u.id %>" class="btn btn-outline-warning" title="Edit"><i class="bi bi-pencil"></i></a>
                                <button type="button" class="btn btn-outline-info" title="Reset Password" data-bs-toggle="modal" data-bs-target="#resetModal<%= u.id %>"><i class="bi bi-key"></i></button>
                                <form method="POST" action="/users/delete/<%= u.id %>" style="display:inline" onsubmit="return confirm('Delete this user?')">
                                    <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                                    <button type="submit" class="btn btn-outline-danger" title="Delete"><i class="bi bi-trash"></i></button>
                                </form>
                            </div>

                            <div class="modal fade" id="resetModal<%= u.id %>" tabindex="-1">
                                <div class="modal-dialog modal-sm">
                                    <div class="modal-content">
                                        <div class="modal-header"><h5 class="modal-title">Reset Password</h5><button type="button" class="btn-close" data-bs-dismiss="modal"></button></div>
                                        <form method="POST" action="/users/reset-password/<%= u.id %>">
                                            <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                                            <div class="modal-body">
                                                <label class="form-label">New Password for <strong><%= u.username %></strong></label>
                                                <input type="password" name="new_password" class="form-control" required minlength="8">
                                            </div>
                                            <div class="modal-footer">
                                                <button type="button" class="btn btn-secondary btn-sm" data-bs-dismiss="modal">Cancel</button>
                                                <button type="submit" class="btn btn-info btn-sm"><i class="bi bi-key"></i> Reset</button>
                                            </div>
                                        </form>
                                    </div>
                                </div>
                            </div>
                        </td>
                    </tr>
                    <% }); %>
                </tbody>
            </table>
        </div>
        <div id="bulkActions" class="card-footer d-none">
            <button type="submit" class="btn btn-danger btn-sm" onclick="return confirm('Delete selected users?')">
                <i class="bi bi-trash"></i> Delete Selected (<span id="selectedCount">0</span>)
            </button>
        </div>
    </form>
</div>

<script>
document.getElementById('selectAll')?.addEventListener('change', function() {
    document.querySelectorAll('.user-checkbox:not(:disabled)').forEach(cb => cb.checked = this.checked);
    updateBulkActions();
});
document.querySelectorAll('.user-checkbox').forEach(cb => {
    cb.addEventListener('change', updateBulkActions);
});
function updateBulkActions() {
    const count = document.querySelectorAll('.user-checkbox:checked').length;
    document.getElementById('selectedCount').textContent = count;
    document.getElementById('bulkActions').classList.toggle('d-none', count === 0);
}
</script>
