<% title = 'Dashboard' %>
<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h4 class="fw-bold mb-0"><i class="bi bi-speedometer2 me-2"></i> Dashboard</h4>
        <small class="text-muted">Welcome back, <strong><%= user.username %></strong>!</small>
    </div>
    <span class="badge bg-primary fs-6 px-3 py-2"><i class="bi bi-person-circle me-1"></i> <%= user.username %></span>
</div>

<% if (typeof pendingRequests !== 'undefined' && pendingRequests > 0) { %>
<div class="alert alert-info alert-dismissible fade show d-flex align-items-center border-start border-info border-4">
    <i class="bi bi-person-gear fs-4 me-3"></i>
    <div><strong><%= pendingRequests %> user(s)</strong> requested password change. <a href="/users" class="alert-link">Manage Users</a></div>
    <button type="button" class="btn-close ms-auto" data-bs-dismiss="alert"></button>
</div>
<% } %>

<% if (expiringWarranty && expiringWarranty.length > 0) { %>
<div class="alert alert-warning alert-dismissible fade show d-flex align-items-center border-start border-warning border-4">
    <i class="bi bi-exclamation-triangle fs-4 me-3"></i>
    <div><strong><%= expiringWarranty.length %> item(s)</strong> warranty expiring within 30 days. <a href="/reports" class="alert-link">Generate Report</a></div>
    <button type="button" class="btn-close ms-auto" data-bs-dismiss="alert"></button>
</div>
<% } %>

<div class="row g-3 mb-4">
    <div class="col-6 col-lg-3">
        <div class="stat-card blue">
            <div class="stat-icon"><i class="bi bi-laptop"></i></div>
            <div class="stat-number"><%= stats.totalItems %></div>
            <div class="stat-label">Total Items</div>
        </div>
    </div>
    <div class="col-6 col-lg-3">
        <div class="stat-card green">
            <div class="stat-icon"><i class="bi bi-check-circle"></i></div>
            <div class="stat-number"><%= stats.available %></div>
            <div class="stat-label">Available</div>
        </div>
    </div>
    <div class="col-6 col-lg-3">
        <div class="stat-card orange">
            <div class="stat-icon"><i class="bi bi-person-check"></i></div>
            <div class="stat-number"><%= stats.allocated %></div>
            <div class="stat-label">Allocated</div>
        </div>
    </div>
    <div class="col-6 col-lg-3">
        <div class="stat-card red">
            <div class="stat-icon"><i class="bi bi-tools"></i></div>
            <div class="stat-number"><%= stats.maintenanceCount %></div>
            <div class="stat-label">Maintenance</div>
        </div>
    </div>
    <div class="col-6 col-lg-3">
        <div class="stat-card purple">
            <div class="stat-icon"><i class="bi bi-people"></i></div>
            <div class="stat-number"><%= stats.totalEmployees %></div>
            <div class="stat-label">Employees</div>
        </div>
    </div>
    <div class="col-6 col-lg-3">
        <div class="stat-card info">
            <div class="stat-icon"><i class="bi bi-shield-check"></i></div>
            <div class="stat-number"><%= stats.underWarranty %></div>
            <div class="stat-label">Under Warranty</div>
        </div>
    </div>
    <div class="col-6 col-lg-3">
        <div class="stat-card teal">
            <div class="stat-icon"><i class="bi bi-currency-rupee"></i></div>
            <div class="stat-number"><i class="bi bi-currency-rupee"></i><%= Number(stats.totalValue).toLocaleString() %></div>
            <div class="stat-label">Total Value</div>
        </div>
    </div>
    <div class="col-6 col-lg-3">
        <div class="stat-card dark">
            <div class="stat-icon"><i class="bi bi-arrow-left-right"></i></div>
            <div class="stat-number"><%= stats.activeAllocations %></div>
            <div class="stat-label">Active Allocations</div>
        </div>
    </div>
</div>

<div class="row g-3 mb-4">
    <div class="col-lg-8">
        <div class="card h-100">
            <div class="card-header d-flex justify-content-between align-items-center">
                <span><i class="bi bi-pie-chart me-1"></i> Category Overview</span>
            </div>
            <div class="card-body">
                <% if (categoryStats && categoryStats.length > 0) { %>
                <canvas id="categoryChart" height="200"></canvas>
                <% } else { %>
                <p class="text-muted text-center py-4">No items to display</p>
                <% } %>
            </div>
        </div>
    </div>
    <div class="col-lg-4">
        <div class="card h-100">
            <div class="card-header"><i class="bi bi-list-check me-1"></i> Category Breakdown</div>
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-hover mb-0">
                        <thead class="table-light"><tr><th>Category</th><th>Count</th></tr></thead>
                        <tbody>
                            <% if (!categoryStats || categoryStats.length === 0) { %>
                            <tr><td colspan="2" class="text-center text-muted py-4">No data</td></tr>
                            <% } %>
                            <% if (categoryStats) { categoryStats.forEach(c => { %>
                            <tr>
                                <td><%= c.category %></td>
                                <td><span class="badge bg-secondary"><%= c.count %></span></td>
                            </tr>
                            <% }); } %>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="row g-3 mb-4">
    <div class="col-md-6">
        <div class="card h-100">
            <div class="card-header d-flex justify-content-between align-items-center">
                <span><i class="bi bi-clock-history me-1"></i> Recent Items</span>
                <a href="/items" class="btn btn-sm btn-outline-primary">View All</a>
            </div>
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-hover mb-0">
                        <thead class="table-light"><tr><th>Asset Tag</th><th>Category</th><th>Status</th></tr></thead>
                        <tbody>
                            <% if (recentItems.length === 0) { %>
                            <tr><td colspan="3" class="text-center text-muted py-4">No items yet</td></tr>
                            <% } %>
                            <% recentItems.forEach(item => { %>
                            <tr>
                                <td><a href="/items/view/<%= item.id %>" class="fw-medium"><%= item.asset_tag %></a></td>
                                <td><%= item.category %></td>
                                <td>
                                    <% if (item.status === 'available') { %><span class="badge bg-success">Available</span>
                                    <% } else if (item.status === 'allocated') { %><span class="badge bg-warning text-dark">Allocated</span>
                                    <% } else if (item.status === 'maintenance') { %><span class="badge bg-danger">Maintenance</span>
                                    <% } %></td>
                            </tr>
                            <% }); %>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-6">
        <div class="card h-100">
            <div class="card-header d-flex justify-content-between align-items-center">
                <span><i class="bi bi-arrow-left-right me-1"></i> Recent Allocations</span>
                <a href="/allocations" class="btn btn-sm btn-outline-primary">View All</a>
            </div>
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-hover mb-0">
                        <thead class="table-light"><tr><th>Asset</th><th>Employee</th><th>Status</th></tr></thead>
                        <tbody>
                            <% if (!recentAllocations || recentAllocations.length === 0) { %>
                            <tr><td colspan="3" class="text-center text-muted py-4">No allocations yet</td></tr>
                            <% } %>
                            <% if (recentAllocations) { recentAllocations.forEach(a => { %>
                            <tr>
                                <td><%= a.asset_tag || '-' %></td>
                                <td><%= a.emp_name || '-' %></td>
                                <td><span class="badge bg-<%= a.status === 'active' ? 'warning text-dark' : 'success' %>"><%= a.status %></span></td>
                            </tr>
                            <% }); } %>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

<% if (expiringWarranty && expiringWarranty.length > 0) { %>
<div class="card mb-4 border border-warning">
    <div class="card-header bg-warning bg-opacity-10 d-flex justify-content-between align-items-center">
        <span><i class="bi bi-shield-exclamation me-1"></i> Warranty Expiring Soon</span>
        <a href="/reports/warranty/pdf" class="btn btn-sm btn-outline-danger"><i class="bi bi-file-earmark-pdf"></i> Export</a>
    </div>
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover mb-0">
                <thead class="table-light"><tr><th>Asset Tag</th><th>Brand</th><th>Model</th><th>Serial No.</th><th>Warranty Ends</th><th>Days Left</th></tr></thead>
                <tbody>
                    <% expiringWarranty.forEach(item => { 
                        const now = new Date();
                        const end = item.warranty_end ? new Date(item.warranty_end) : new Date();
                        const daysLeft = Math.ceil((end - now) / (1000*60*60*24));
                    %>
                    <tr>
                        <td class="fw-medium"><%= item.asset_tag %></td>
                        <td><%= item.brand || '-' %></td>
                        <td><%= item.model || '-' %></td>
                        <td><code><%= item.serial_number || '-' %></code></td>
                        <td><%= item.warranty_end %></td>
                        <td><span class="badge bg-<%= daysLeft <= 7 ? 'danger' : 'warning text-dark' %>"><%= daysLeft %> days</span></td>
                    </tr>
                    <% }); %>
                </tbody>
            </table>
        </div>
    </div>
</div>
<% } %>

<div class="card">
    <div class="card-body d-flex gap-2 flex-wrap">
        <a href="/items/add" class="btn btn-primary"><i class="bi bi-plus-lg"></i> Add Item</a>
        <a href="/bulk/items" class="btn btn-outline-primary"><i class="bi bi-upload"></i> Bulk Import</a>
        <a href="/bulk/employees" class="btn btn-outline-success"><i class="bi bi-upload"></i> Bulk Employees</a>
        <a href="/employees/add" class="btn btn-success"><i class="bi bi-plus-lg"></i> Add Employee</a>
        <a href="/allocations/allocate" class="btn btn-warning"><i class="bi bi-plus-lg"></i> New Allocation</a>
        <a href="/maintenance/add" class="btn btn-danger"><i class="bi bi-plus-lg"></i> Log Maintenance</a>
        <a href="/reports" class="btn btn-info text-white"><i class="bi bi-file-earmark-bar-graph"></i> Reports</a>
    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
<script>
    <% if (categoryStats && categoryStats.length > 0) { %>
    new Chart(document.getElementById('categoryChart'), {
        type: 'doughnut',
        data: {
            labels: [<% categoryStats.forEach((c,i) => { %><%- JSON.stringify(c.category) %><%= i < categoryStats.length - 1 ? ',' : '' %><% }); %>],
            datasets: [{
                data: [<% categoryStats.forEach((c,i) => { %><%= c.count %><%= i < categoryStats.length - 1 ? ',' : '' %><% }); %>],
                backgroundColor: ['#0d6efd','#198754','#ffc107','#dc3545','#6f42c1','#0dcaf0','#20c997','#fd7e14','#d63384'],
                borderWidth: 2,
                borderColor: '#fff'
            }]
        },
        options: {
            responsive: true,
            maintainAspectRatio: true,
            plugins: {
                legend: { position: 'right', labels: { font: { size: 11 }, padding: 12 } }
            }
        }
    });
    <% } %>
</script>
